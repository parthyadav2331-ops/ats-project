PORT=5001
JWT_SECRET=change-me-to-a-long-random-string

# --- Database ---
# Option A (recommended): Neon (or any hosted Postgres). Just paste the
# connection string. SSL is enabled automatically when DATABASE_URL is set.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# Option B: Local Postgres. Leave DATABASE_URL unset and fill these instead.
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=careersfit
